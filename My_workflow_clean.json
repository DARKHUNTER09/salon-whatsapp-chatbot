    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nif (!body) {\n  return [{ json: { skip: true, intent: 'unknown', from: 'unknown', to: '', replyText: '' } }];\n}\n\nconst from = body.From || '';\nconst to = body.To || '';\nconst text = (body.Body || '').toLowerCase().trim();\nconst customerName = body.ProfileName || 'Guest';\n\nif (!text) {\n  return [{ json: { skip: true, intent: 'unknown', from, to, replyText: '' } }];\n}\n\nlet intent = 'unknown';\nif (/^(hi|hello|hey|hii|hiii|helo|namaste|start|help)/.test(text)) {\n  intent = 'greeting';\n} else if (/book|booking|appointment/.test(text)) {\n  intent = 'book';\n} else if (/menu|service|price|haircut|facial|massage|manicure|pedicure|color/.test(text)) {\n  intent = 'menu';\n} else if (/staff|stylist|team|barber|beautician/.test(text)) {\n  intent = 'staff';\n} else if (/offer|discount|deal|promo|special/.test(text)) {\n  intent = 'offers';\n} else if (/status|my booking|confirm|track/.test(text)) {\n  intent = 'status';\n}\n\nreturn [{\n  json: {\n    from,\n    to,\n    customerName,\n    text,\n    intent,\n    skip: false,\n    replyText: ''\n  }\n}];"
      },
