        "jsCode": "// Hardcoded menu — ya Google Sheets node se replace kar sakte ho\nconst reply = `💅 *Services & Prices*\n\n*── Hair ──*\n• Haircut (Men) — ₹200 (30 min)\n• Haircut (Women) — ₹350 (45 min)\n• Hair Color — ₹800 (90 min)\n• Keratin Treatment — ₹2500 (3 hrs)\n\n*── Skin ──*\n• Facial — ₹600 (60 min)\n• Cleanup — ₹300 (30 min)\n• D-Tan — ₹400 (45 min)\n\n*── Nails ──*\n• Manicure — ₹400 (45 min)\n• Pedicure — ₹500 (60 min)\n\n📞 Book karne ke liye *book* type karo!`;\nreturn [{ json: { ...$json, replyText: reply } }];"
      },
